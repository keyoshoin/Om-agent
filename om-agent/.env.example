# OM-Agent 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ─── DeepSeek LLM 配置 ─────────────────────────────────────────────
# 必填: DeepSeek API Key (从 https://platform.deepseek.com 获取)
DEEPSEEK_API_KEY=sk-your-key-here

# 可选: API 地址 (默认使用 DeepSeek 官方)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 可选: 模型名称
DEEPSEEK_MODEL=deepseek-v4-flash

# ─── API 认证 ──────────────────────────────────────────────────────
# 必填: API 访问密钥 (用于前端/API 调用的认证)
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
OM_AGENT_API_KEY=change-me-to-a-random-string

# ─── 密码加密 ──────────────────────────────────────────────────────
# 必填: 数据库密码加密密钥
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OM_AGENT_ENCRYPTION_KEY=generate-with-python-cryptography-fernet

# ─── SSH 可选配置 ──────────────────────────────────────────────────
# 可选: SSH known_hosts 文件路径 (留空则跳过主机密钥验证，仅限内网使用)
SSH_KNOWN_HOSTS_PATH=